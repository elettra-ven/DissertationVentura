@article{kohlbacherApplicationsNovelQuantitative2022,
  title = {Applications of the {{Novel Quantitative Pharmacophore Activity Relationship Method QPhAR}} in {{Virtual Screening}} and {{Lead-Optimisation}}},
  author = {Kohlbacher, Stefan Michael and Schmid, Matthias and Seidel, Thomas and Langer, Thierry},
  year = 2022,
  month = sep,
  journal = {Pharmaceuticals},
